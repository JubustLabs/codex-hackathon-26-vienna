{
  "name": "converge",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx concurrently -n server,client -c auto \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "bun --watch src/server/index.ts",
    "client:dev": "vite",
    "build": "vite build",
    "check": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.8.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "openai": "^6.34.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "bun-types": "^1.3.12",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
