{
  "name": "governed-kb-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node --watch src/server/index.js",
    "dev:web": "vite --config web/vite.config.ts",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "build:web": "vite build --config web/vite.config.ts",
    "check": "tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
